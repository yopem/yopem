{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./router": {
      "types": "./src/root.ts",
      "default": "./src/root.ts"
    },
    "./orpc": {
      "types": "./src/orpc.ts",
      "default": "./src/orpc.ts"
    },
    "./rate-limit": {
      "types": "./src/rate-limit.ts",
      "default": "./src/rate-limit.ts"
    }
  },
  "scripts": {
    "dev": "dotenv -e ../../.env -- bun run with-env bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run with-env bun run dist/index.js",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@orpc/server": "^1.13.13",
    "@polar-sh/hono": "^0.5.5",
    "@polar-sh/sdk": "^0.46.7",
    "auth": "workspace:*",
    "cache": "workspace:*",
    "db": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "env": "workspace:*",
    "hono": "^4.12.9",
    "ioredis": "^5.10.1",
    "llm": "workspace:*",
    "payments": "workspace:*",
    "shared": "workspace:*",
    "storage": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@yopem/typescript-config": "^0.2.1",
    "dotenv-cli": "^11.0.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "typescript": "^6.0.2"
  }
}
