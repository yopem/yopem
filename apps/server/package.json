{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./router": {
      "types": "./src/root.ts",
      "default": "./src/root.ts"
    },
    "./orpc": {
      "types": "./src/orpc.ts",
      "default": "./src/orpc.ts"
    },
    "./rate-limit": {
      "types": "./src/rate-limit.ts",
      "default": "./src/rate-limit.ts"
    }
  },
  "scripts": {
    "dev": "vp run with-env node --watch --experimental-strip-types src/index.ts",
    "build": "vp run with-env tsdown src/index.ts --outDir dist",
    "start": "node dist/index.js",
    "lint": "vp lint .",
    "lint:fix": "vp lint --fix .",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/openai-compatible": "catalog:",
    "@aws-sdk/client-s3": "catalog:",
    "@hono/node-server": "^1.19.12",
    "@orpc/server": "catalog:",
    "@polar-sh/hono": "^0.5.5",
    "@polar-sh/sdk": "catalog:",
    "ai": "catalog:",
    "auth": "workspace:*",
    "db": "workspace:*",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "env": "workspace:*",
    "hono": "^4.12.9",
    "ioredis": "catalog:",
    "nanoid": "catalog:",
    "pg": "catalog:",
    "shared": "workspace:*",
    "sharp": "^0.34.5",
    "transliteration": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@yopem/typescript-config": "catalog:",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
