{
  "name": "yopem",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@ai-sdk/openai": "^3.0.29",
      "@ai-sdk/openai-compatible": "^2.0.30",
      "@aws-sdk/client-s3": "^3.990.0",
      "@openauthjs/openauth": "^0.4.3",
      "@orpc/client": "^1.13.5",
      "@orpc/server": "^1.13.13",
      "@orpc/tanstack-query": "^1.13.5",
      "@polar-sh/sdk": "^0.46.7",
      "@t3-oss/env-core": "^0.13.10",
      "@tailwindcss/postcss": "^4.1.18",
      "@tailwindcss/vite": "^4.2.2",
      "@tanstack/react-form": "^1.28.6",
      "@tanstack/react-query": "^5.96.1",
      "@tanstack/react-router": "^1.168.10",
      "@tanstack/react-start": "^1.167.16",
      "@types/node": "^25.2.3",
      "@types/pg": "^8.20.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "@unpic/react": "^1.0.2",
      "@vitejs/plugin-react": "^5.2.0",
      "@yopem/typescript-config": "^0.2.1",
      "ai": "^6.0.86",
      "babel-plugin-react-compiler": "^1.0.0",
      "dayjs": "^1.11.19",
      "drizzle-kit": "^0.31.10",
      "drizzle-orm": "^0.45.2",
      "drizzle-zod": "^0.8.3",
      "eslint-plugin-better-tailwindcss": "^4.3.0",
      "ioredis": "^5.10.1",
      "lucide-react": "^1.7.0",
      "nanoid": "^5.1.6",
      "next-themes": "^0.4.6",
      "pg": "^8.18.0",
      "postcss": "^8.5.6",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "server-only": "^0.0.1",
      "shimmer-from-structure": "^2.4.2",
      "tailwind-merge": "^3.4.1",
      "tailwindcss": "^4.2.2",
      "transliteration": "^2.6.1",
      "typescript": "6.0.2",
      "vite": "npm:@voidzero-dev/vite-plus-core@0.2.1",
      "vite-tsconfig-paths": "^6.1.1",
      "zod": "^4.3.6",
      "vite-plus": "0.2.1"
    }
  },
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "build:admin": "vp build apps/admin",
    "build:web": "vp build apps/web",
    "build:server": "vp run --filter server build",
    "dev": "vp run -r --parallel dev",
    "dev:admin": "vp dev apps/admin",
    "dev:web": "vp dev apps/web",
    "dev:server": "vp run --filter server dev",
    "start": "vp run -r start",
    "start:admin": "vp run --filter admin start",
    "start:web": "vp run --filter web start",
    "start:server": "vp run --filter server start",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format:check": "vp fmt --check .",
    "format:write": "vp fmt --write .",
    "typecheck": "vp run -r typecheck",
    "check": "vp check",
    "fix": "vp lint --fix && vp fmt --write .",
    "db:generate": "vp run --filter db db:generate",
    "db:migrate": "vp run --filter db db:migrate",
    "db:studio": "vp run --filter db db:studio",
    "ui-add": "cd packages/ui && vpx shadcn@latest add"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@yopem/typescript-config": "^0.2.1",
    "typescript": "^6.0.2",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
