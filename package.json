      "@yopem/typescript-config": "^0.2.1",
      "ai": "^6.0.86",
      "babel-plugin-react-compiler": "^1.0.0",
      "dayjs": "^1.11.19",
      "dotenv-cli": "^11.0.0",
      "drizzle-kit": "^0.31.10",
      "drizzle-orm": "^0.45.2",
      "drizzle-zod": "^0.8.3",
      "eslint-plugin-better-tailwindcss": "^4.3.0",
      "ioredis": "^5.10.1",
      "lucide-react": "^1.7.0",
      "nanoid": "^5.1.6",
      "next-themes": "^0.4.6",
      "oxfmt": "^0.43.0",
      "oxlint": "^1.47.0",
      "oxlint-tsgolint": "^0.19.0",
      "pg": "^8.18.0",
      "postcss": "^8.5.6",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "server-only": "^0.0.1",
      "shimmer-from-structure": "^2.4.2",
      "tailwind-merge": "^3.4.1",
      "tailwindcss": "^4.2.2",
      "transliteration": "^2.6.1",
      "typescript": "6.0.2",
      "vite": "^8.0.3",
      "vite-tsconfig-paths": "^6.1.1",
      "zod": "^4.3.6"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:admin": "turbo run build --filter=admin",
    "build:web": "turbo run build --filter=web",
    "build:server": "turbo run build --filter=server",
    "dev": "turbo run dev",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:web": "turbo run dev --filter=web",
    "dev:server": "turbo run dev --filter=server",
    "start": "turbo run start",
    "start:admin": "turbo run start --filter=admin",
    "start:web": "turbo run start --filter=web",
    "start:server": "turbo run start --filter=server",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "typecheck": "turbo run typecheck",
    "check": "turbo run lint typecheck && oxfmt --check .",
    "fix": "turbo run lint:fix && oxfmt --write .",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "turbo run db:studio",
    "ui-add": "cd packages/ui && bun x shadcn@latest add"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@yopem/typescript-config": "^0.2.1",
    "dotenv-cli": "^11.0.0",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.20.0",
    "portless": "^0.10.1",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.10"
}
