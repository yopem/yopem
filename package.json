{
  "name": "yopem",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "build:admin": "vp build apps/admin",
    "build:web": "vp build apps/web",
    "build:server": "vp run --filter server build",
    "dev": "vp run -r --parallel dev",
    "dev:admin": "vp run --filter admin dev",
    "dev:web": "vp run --filter web dev",
    "dev:server": "vp run --filter server dev",
    "start": "vp run -r start",
    "start:admin": "vp run --filter admin start",
    "start:web": "vp run --filter web start",
    "start:server": "vp run --filter server start",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format:check": "vp fmt --check .",
    "format:write": "vp fmt --write .",
    "typecheck": "vp run -r typecheck",
    "check": "vp check",
    "fix": "vp lint --fix && vp fmt --write .",
    "db:generate": "vp run --filter db db:generate",
    "db:migrate": "vp run --filter db db:migrate",
    "db:studio": "vp run --filter db db:studio",
    "ui-add": "cd packages/ui && vpx shadcn@latest add"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@yopem/typescript-config": "catalog:",
    "dotenv-cli": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:"
  },
  "packageManager": "pnpm@10.12.1"
}
