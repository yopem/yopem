      "@tailwindcss/postcss": "^4.1.18",
      "@tailwindcss/vite": "^4.2.2",
      "@tanstack/react-form": "^1.28.6",
      "@tanstack/react-query": "^5.96.1",
      "@tanstack/react-router": "^1.168.10",
      "@tanstack/react-start": "^1.167.16",
      "@types/node": "^25.2.3",
      "@types/pg": "^8.20.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
