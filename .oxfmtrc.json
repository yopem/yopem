{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "bracketSpacing": true,
  "jsxSingleQuote": false,
  "printWidth": 80,
  "proseWrap": "always",
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "experimentalTailwindcss": {
    "functions": ["cn", "cva", "clsx"]
  },
  "experimentalSortPackageJson": true,
  "ignorePatterns": [
    "node_modules",
    ".pnp",
    ".pnp.js",
    ".env",
    ".env.local",
    ".env.development.local",
    ".env.test.local",
    ".env.production.local",
    "coverage",
    ".turbo",
    ".vercel",
    ".next/",
    "out/",
    "build",
    "dist",
    "npm-debug.log*",
    "yarn-debug.log*",
    "yarn-error.log*",
    ".DS_Store",
    "*.pem",
    "migrations/",
    "tsconfig.tsbuildinfo",
    "*.tsbuildinfo",
    "next-env.d.ts",
    "routeTree.gen.ts",
    "**/migrations/**"
  ],
  "sortImports": {
    "newlinesBetween": true,
    "customGroups": [
      {
        "groupName": "value-workspace",
        "elementNamePattern": [
          "ui",
          "ui/**",
          "auth",
          "auth/**",
          "db",
          "db/**",
          "env",
          "env/**",
          "logger",
          "logger/**",
          "rpc",
          "rpc/**",
          "shared",
          "shared/**",
          "cache",
          "cache/**",
          "llm",
          "llm/**",
          "payments",
          "payments/**",
          "storage",
          "storage/**"
        ]
      },
      {
        "groupName": "type-workspace",
        "elementNamePattern": [
          "ui",
          "ui/**",
          "auth",
          "auth/**",
          "db",
          "db/**",
          "env",
          "env/**",
          "logger",
          "logger/**",
          "rpc",
          "rpc/**",
          "shared",
          "shared/**",
          "cache",
          "cache/**",
          "llm",
          "llm/**",
          "payments",
          "payments/**",
          "storage",
          "storage/**"
        ]
      }
    ],
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      "type-workspace",
      "value-workspace",
      "type-internal",
      "value-internal",
      ["type-parent", "type-sibling", "type-index"],
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  }
}
