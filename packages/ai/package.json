{
  "name": "ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./executor": {
      "types": "./src/executor.ts",
      "default": "./src/executor.ts"
    },
    "./providers": {
      "types": "./src/providers/base.ts",
      "default": "./src/providers/base.ts"
    }
  },
  "scripts": {
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/openai-compatible": "catalog:",
    "ai": "catalog:",
    "better-result": "catalog:",
    "logger": "workspace:*",
    "storage": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@yopem/typescript-config": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:"
  }
}
