{
  "name": "env",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./ports": {
      "types": "./src/ports.ts",
      "default": "./src/ports.ts"
    }
  },
  "scripts": {
    "lint": "vp lint .",
    "lint:fix": "vp lint --fix .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@yopem/typescript-config": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
