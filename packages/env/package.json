{
  "name": "env",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./hono": {
      "types": "./src/hono.ts",
      "default": "./src/hono.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./ports": {
      "types": "./src/ports.ts",
      "default": "./src/ports.ts"
    }
  },
  "scripts": {
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@yopem/typescript-config": "^0.2.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "^6.0.2"
  }
}
