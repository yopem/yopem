{
  "name": "rpc",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./shared": {
      "types": "./src/shared.ts",
      "default": "./src/shared.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./query": {
      "types": "./src/query.ts",
      "default": "./src/query.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./server-query": {
      "types": "./src/server-query.ts",
      "default": "./src/server-query.ts"
    },
    "./prefetch": {
      "types": "./src/prefetch.ts",
      "default": "./src/prefetch.ts"
    },
    "./serializer": {
      "types": "./src/serializer.tsx",
      "default": "./src/serializer.tsx"
    },
    "./query-client": {
      "types": "./src/query-client.tsx",
      "default": "./src/query-client.tsx"
    },
    "./provider": {
      "types": "./src/provider.tsx",
      "default": "./src/provider.tsx"
    },
    "./hydration": {
      "types": "./src/hydration.tsx",
      "default": "./src/hydration.tsx"
    }
  },
  "scripts": {
    "lint": "vp lint .",
    "lint:fix": "vp lint --fix .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@orpc/client": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/tanstack-query": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-start": "catalog:",
    "env": "workspace:*",
    "react": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@yopem/typescript-config": "catalog:",
    "server": "workspace:*",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
