{
  "$schema": "../../node_modules/oxfmt/configuration_schema.json",
  "bracketSpacing": true,
  "jsxSingleQuote": false,
  "printWidth": 80,
  "proseWrap": "always",
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "experimentalSortPackageJson": true,
  "ignorePatterns": ["node_modules", ".next/", "dist", "build", "migrations/"],
  "sortImports": {
    "newlinesBetween": true,
    "customGroups": [
      {
        "groupName": "value-workspace",
        "elementNamePattern": [
          "ui",
          "ui/**",
          "auth",
          "auth/**",
          "db",
          "db/**",
          "env",
          "env/**",
          "logger",
          "logger/**",
          "rpc",
          "rpc/**",
          "shared",
          "shared/**",
          "cache",
          "cache/**",
          "ai",
          "ai/**",
          "payments",
          "payments/**",
          "storage",
          "storage/**"
        ]
      },
      {
        "groupName": "type-workspace",
        "elementNamePattern": [
          "ui",
          "ui/**",
          "auth",
          "auth/**",
          "db",
          "db/**",
          "env",
          "env/**",
          "logger",
          "logger/**",
          "rpc",
          "rpc/**",
          "shared",
          "shared/**",
          "cache",
          "cache/**",
          "ai",
          "ai/**",
          "payments",
          "payments/**",
          "storage",
          "storage/**"
        ]
      }
    ],
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      "type-workspace",
      "value-workspace",
      "type-internal",
      "value-internal",
      ["type-parent", "type-sibling", "type-index"],
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  }
}
