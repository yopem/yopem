{
  "name": "db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./services/slug": {
      "types": "./src/services/slug.ts",
      "default": "./src/services/slug.ts"
    },
    "./services/tools": {
      "types": "./src/services/tools.ts",
      "default": "./src/services/tools.ts"
    },
    "./services/tags": {
      "types": "./src/services/tags.ts",
      "default": "./src/services/tags.ts"
    },
    "./services/categories": {
      "types": "./src/services/categories.ts",
      "default": "./src/services/categories.ts"
    },
    "./services/assets": {
      "types": "./src/services/assets.ts",
      "default": "./src/services/assets.ts"
    },
    "./services/user": {
      "types": "./src/services/user.ts",
      "default": "./src/services/user.ts"
    },
    "./services/admin": {
      "types": "./src/services/admin.ts",
      "default": "./src/services/admin.ts"
    },
    "./services/subscriptions": {
      "types": "./src/services/subscriptions.ts",
      "default": "./src/services/subscriptions.ts"
    },
    "./services/grandfathered-migration": {
      "types": "./src/services/grandfathered-migration.ts",
      "default": "./src/services/grandfathered-migration.ts"
    },
    "./services/subscription-admin": {
      "types": "./src/services/subscription-admin.ts",
      "default": "./src/services/subscription-admin.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "default": "./src/errors.ts"
    }
  },
  "scripts": {
    "lint": "oxlint --config .oxlintrc.json .",
    "lint:fix": "oxlint --config .oxlintrc.json --fix .",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --",
    "db:generate": "bun run with-env drizzle-kit generate",
    "db:migrate": "bun run with-env drizzle-kit migrate",
    "db:studio": "bun run with-env drizzle-kit studio",
    "db:seed": "bun run with-env bun run src/seed.ts",
    "db:migrate-subscriptions": "bun run with-env bun run scripts/migrate-to-subscriptions.ts"
  },
  "dependencies": {
    "better-result": "^2.7.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "env": "workspace:*",
    "logger": "workspace:*",
    "pg": "^8.20.0",
    "shared": "workspace:*",
    "transliteration": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@yopem/typescript-config": "^0.2.1",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "typescript": "^6.0.2"
  }
}
