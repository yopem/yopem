{
  "name": "db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./services/*": {
      "types": "./src/services/*.ts",
      "default": "./src/services/*.ts"
    }
  },
  "scripts": {
    "db:generate": "with-env drizzle-kit generate",
    "db:migrate": "with-env drizzle-kit migrate",
    "db:studio": "with-env drizzle-kit studio",
    "lint": "vp lint .",
    "lint:fix": "vp lint --fix .",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "env": "workspace:*",
    "pg": "catalog:",
    "shared": "workspace:*",
    "transliteration": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@yopem/typescript-config": "^0.2.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
