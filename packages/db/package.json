{
  "name": "db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./schema/*": {
      "types": "./src/schema/*.ts",
      "default": "./src/schema/*.ts"
    },
    "./services/*": {
      "types": "./src/services/*.ts",
      "default": "./src/services/*.ts"
    }
  },
  "scripts": {
    "db:generate": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs migrate",
    "db:seed": "tsx --env-file=../../.env src/seed.ts",
    "db:studio": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs studio",
    "lint": "vp lint .",
    "lint:fix": "vp lint --fix .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "env": "workspace:*",
    "pg": "catalog:",
    "transliteration": "catalog:",
    "utils": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@yopem/typescript-config": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
